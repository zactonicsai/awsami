# Line-ending law for a mixed Windows/Linux team with synced GitLab instances.
# Prevents CRLF-churn commits that turn every sync into a phantom diff.
*        text=auto
*.sh     text eol=lf
*.py     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.tf     text eol=lf
*.hcl    text eol=lf
*.j2     text eol=lf
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf
*.png    binary
*.zip    binary
