# {{ ansible_managed }}
[Unit]
Description=Apache ZooKeeper
After=network-online.target

[Service]
Type=forking
User={{ zookeeper_user }}
ExecStart=/opt/zookeeper/bin/zkServer.sh start
ExecStop=/opt/zookeeper/bin/zkServer.sh stop
Restart=on-failure
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
